APP_NAME=CorpChat
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Logging Configuration
LOG_CHANNEL=stack
LOG_STACK=single,slack
LOG_LEVEL=debug
LOG_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL


# Database (MySQL 8.0)
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=corpchat
DB_USERNAME=corpchat
DB_PASSWORD=secret

# Redis (Cache, Sessions, Queues)
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Reverb (WebSockets)
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=corpchat_id
REVERB_APP_KEY=corpchat_key
REVERB_APP_SECRET=corpchat_secret
REVERB_HOST=reverb-server
REVERB_PORT=8080
REVERB_SCHEME=http

# Hostinger SMTP (Outbound Emails)
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=employee@company.com
MAIL_PASSWORD=your_hostinger_password
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=employee@company.com
MAIL_FROM_NAME="${APP_NAME}"

# Hostinger IMAP (Inbound Emails via webklex/laravel-imap)
IMAP_HOST=imap.hostinger.com
IMAP_PORT=993
IMAP_ENCRYPTION=ssl
IMAP_VALIDATE_CERT=true
IMAP_USERNAME=employee@company.com
IMAP_PASSWORD=your_hostinger_password
IMAP_DEFAULT_ACCOUNT=default
IMAP_PROTOCOL=imap
